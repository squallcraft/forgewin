# football-data.org API (https://www.football-data.org/)
FOOTBALL_DATA_ORG_TOKEN=your_api_key_here

# Grok (xAI) para análisis y chatbot - https://console.x.ai/
XAI_API_KEY=your_grok_api_key_here
# Alternativo:
# GROK_API_KEY=your_grok_api_key_here

# Gemini (Google) para análisis de propuestas - https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Alternativo:
# GOOGLE_API_KEY=your_gemini_api_key_here
# Primer análisis (Reginald) y pasos 1-5 del consenso: Flash. Solo consenso final (paso 6) usa Pro.
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL_CONSENSUS=gemini-2.5-pro

# Base de datos
# LOCAL (SQLite — sin esta variable, se usa SQLite automáticamente):
# FOOTBALL_DB_PATH=/ruta/forgewin.db
#
# PRODUCCIÓN (PostgreSQL — cuando DATABASE_URL está definida, SQLite se ignora):
# DATABASE_URL=postgresql://forgewin:forgewin@localhost:5432/forgewin
# DigitalOcean Managed PostgreSQL ejemplo:
# DATABASE_URL=postgresql://doadmin:PASS@db-forgewin-xxxxx.db.ondigitalocean.com:25060/forgewin?sslmode=require

# Cuotas de casas de apuesta - The Odds API (opcional; https://the-odds-api.com/)
# ODDS_API_KEY=your_odds_api_key
# THE_ODDS_API_KEY=your_odds_api_key
# Sin key se usa solo Poisson. Con use_mock=True se usan cuotas de ejemplo.

# API-Sports (api-sports.io) - ForgeWin está configurado para plan Pro (300 req/min).
# - xG y lesiones (data_integrators)
# - Partidos Europa League, Copa Libertadores y resto de ligas (fuente principal)
# Obtener: https://www.api-football.com/
# API_FOOTBALL_KEY=your_api_football_key
# Delay por defecto 0.25 s (Pro). Override solo si usas otro plan: API_FOOTBALL_REQUEST_DELAY=6
# API_FOOTBALL_REQUEST_DELAY=0.25

# TheSportsDB: fallback secundario de partidos. No requiere API key (usa key compartida gratis).

# Mercado Pago - pagos y suscripciones (opcional)
# Obtener: https://www.mercadopago.com.ar/developers/panel/credentials
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx
# FORGEWIN_BASE_URL=https://tu-dominio.com
# MP_WEBHOOK_URL=https://tu-dominio.com/webhooks/mercadopago

# Envío de propuestas por correo (opcional)
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_USER=tu_usuario
# SMTP_PASSWORD=tu_contraseña
# EMAIL_FROM=noreply@tudominio.com
